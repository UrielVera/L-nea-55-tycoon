​1. Modelos de Datos (CoreModels.cs)
​Mantené este único archivo para las clases de datos. Eliminá cualquier otro que tenga las clases Chofer o Unidad.

using System;
using UnityEngine;

[Serializable]
public class Chofer
{
    public string nombre;
    public string personalidad; // "Agresivo", "Tranquilo", "Vago", "Pro"
    public float sueldo;
    public float cansancio;
    public float moral;
    public bool contratado;

    public Chofer(string n, string p, float s, float m) {
        nombre = n; personalidad = p; sueldo = s; moral = m;
        cansancio = 0; contratado = false;
    }
}

[Serializable]
public class Unidad
{
    public int id;
    public int motorLvl = 1;
    public int frenosLvl = 1;
    public int pasajeros = 0;
    public int capacidad = 70;
    public int currentStopIdx = -1; // -1 = En terminal
    public float progreso = 0f;
    public float averiadoTimer = 0f;
    public int viajesSinService = 0;
    public RouteData rutaAsignada;
    public Chofer choferAsignado;

    public void Reset() {
        currentStopIdx = -1;
        progreso = 0;
        pasajeros = 0;
        choferAsignado = null;
        rutaAsignada = null;
    }
}


